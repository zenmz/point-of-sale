# Server
APP_PORT=8080
APP_ENV=development

# Database
DATABASE_URL=postgres://mzpos:mzpos@localhost:5432/mzpos?sslmode=disable

# Auth
# PRODUKSI (APP_ENV=production): JWT_SECRET WAJIB diganti (min. 16 karakter,
# bukan nilai default) — app menolak start bila tidak. Default expiry 12 jam.
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=12

# CORS: origin diizinkan, dipisah koma. Kosong = izinkan semua (dev).
# PRODUKSI: WAJIB diisi (mis. https://app.contoh.com) — app menolak start bila kosong.
CORS_ORIGINS=
